# Siphon API configuration
# Copy to .env (or export in your process manager) and adjust per environment.

# HTTP server
PORT=8787
HOST=0.0.0.0

# Comma-separated list of origins allowed to call the API from a browser.
# Use * only for local development.
ALLOWED_ORIGINS=http://localhost:5173

# Secret used to sign download tokens (HMAC-SHA256).
# Generate with: openssl rand -hex 32
SIGNING_SECRET=change-me-to-a-long-random-secret

# Seconds a signed download URL stays valid.
TOKEN_TTL_SECONDS=1800

# External tools. yt-dlp must be on PATH or set an absolute path here.
# ffmpeg must be on PATH for MP3 extraction and 1080p+ muxing.
YTDLP_PATH=yt-dlp

# Concurrency guards
MAX_CONCURRENT_EXTRACTIONS=4
MAX_CONCURRENT_STREAMS=6

# Metadata cache (seconds) for repeated resolves of the same URL.
RESOLVE_CACHE_TTL_SECONDS=300

# Rate limiting (per client IP)
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MINUTES=1

# Hard ceiling for a single proxied download, in megabytes. 0 disables the cap.
MAX_DOWNLOAD_SIZE_MB=4096

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
