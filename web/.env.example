# Leave empty (default) when the web app and API share one origin, e.g. an
# nginx reverse proxy sending /api/* to the backend — see docs/deployment.md.
#
# Set to the API's absolute origin when they're deployed as two separate
# services with different domains (e.g. Render, Netlify + a standalone API
# host). The backend's ALLOWED_ORIGINS must then include this web app's origin.
VITE_API_BASE_URL=
